# Anthropic (for automation only)
ANTHROPIC_API_KEY=your-api-key-here

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
PAGERDUTY_API_KEY=your-pagerduty-key
