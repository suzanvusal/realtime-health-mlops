   "source": [
    "# MLflow Experiment Tracking Setup\n",
    "\n",
    "This notebook sets up the MLflow experiment tracking environment, including the MLflow server, experiment configuration, artifact storage, and model registry initialization."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import mlflow\n",
    "import mlflow.sklearn\n",
    "import os\n",
    "import yaml\n",
    "\n",
    "from mlflow.tracking import MlflowClient\n",
    "\n",
    "def load_config(config_path: str) -> dict:\n",
    "    \"\"\"Load YAML configuration file.\"\"\"\n",
    "    with open(config_path, 'r') as file:\n",
    "        config = yaml.safe_load(file)\n",
    "    return config\n",
    "\n",
    "config = load_config('configs/mlflow_config.yaml')\n",
    "mlflow.set_tracking_uri(config['tracking_uri'])\n",
    "\n",
    "def create_experiment(experiment_name: str) -> str:\n",
    "    \"\"\"Create a new MLflow experiment.\"\"\"\n",
    "    client = MlflowClient()\n",
    "    experiment_id = client.create_experiment(experiment_name)\n",
    "    return experiment_id\n",
    "\n",
    "experiment_name = config['experiment_name']\n",
    "experiment_id = create_experiment(experiment_name)\n",
    "print(f'Experiment created with ID: {experiment_id}')\n",
    "\n",
    "def setup_artifact_location(artifact_location: str) -> None:\n",
    "    \"\"\"Set up artifact storage location for MLflow.\"\"\"\n",
    "    if not os.path.exists(artifact_location):\n",
    "        os.makedirs(artifact_location)\n",
    "    mlflow.set_artifact_uri(artifact_location)\n",
    "\n",
    "artifact_location = config['artifact_location']\n",
    "setup_artifact_location(artifact_location)\n",
    "print(f'Artifact storage location set to: {artifact_location}')\n",
    "\n",
    "def init_model_registry() -> None:\n",
    "    \"\"\"Initialize the model registry in MLflow.\"\"\"\n",
    "    client = MlflowClient()\n",
    "    client.create_registered_model(experiment_name)\n",
    "    print(f'Model registry initialized for: {experiment_name}')\n",
    "\n",
    "init_model_registry()"
   ]
  }
 ],
