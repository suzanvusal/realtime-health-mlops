   "source": [
    "# LSTM Temporal Model for Sequence Prediction\n",
    "\n",
    "This notebook focuses on training an LSTM model using PyTorch for sequence-level patient risk prediction based on temporal health data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from torch.utils.data import DataLoader\n",
    "from src.models.sequence_dataset import SequenceDataset\n",
    "from src.models.lstm_model import LSTMModel\n",
    "from src.models.lstm_trainer import LSTMTrainer\n",
    "import mlflow\n",
    "import mlflow.pytorch\n",
    "\n",
    "# Set device\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "\n",
    "# Load data\n",
    "data = pd.read_csv('data/patient_data.csv')\n",
    "features = data[['feature1', 'feature2', 'feature3']].values\n",
    "labels = data['risk_level'].values\n",
    "\n",
    "# Create sliding window dataset\n",
    "window_size = 10\n",
    "sequence_dataset = SequenceDataset(features, labels, window_size)\n",
    "train_loader = DataLoader(sequence_dataset, batch_size=32, shuffle=True)\n",
    "\n",
    "# Initialize model\n",
    "input_size = features.shape[1]\n",
    "hidden_size = 64\n",
    "num_layers = 2\n",
    "output_size = 1\n",
    "model = LSTMModel(input_size, hidden_size, num_layers, output_size).to(device)\n",
    "\n",
    "# Initialize trainer\n",
    "trainer = LSTMTrainer(model, train_loader, device)\n",
    "\n",
    "# Train model\n",
    "mlflow.start_run()\n",
    "trainer.train(epochs=50)\n",
    "mlflow.pytorch.log_model(model, 'lstm_model')\n",
    "mlflow.end_run()\n",
    "\n",
    "# Save the model\n",
    "torch.save(model.state_dict(), 'models/lstm_model.pth')\n",
    "\n",
    "# Evaluate the model\n",
    "trainer.evaluate()\n",
    "\n",
    "# Visualize results\n",
    "import matplotlib.pyplot as plt\n",
    "plt.plot(trainer.losses)\n",
    "plt.title('Training Loss')\n",
    "plt.xlabel('Epoch')\n",
    "plt.ylabel('Loss')\n",
    "plt.show()"
   ]
  }
 ],
